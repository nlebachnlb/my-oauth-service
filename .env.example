# =============================================================================
# auth-service-oauth-jwt — Environment Variables Template
# Copy file này thành .env và điền giá trị thực vào
# =============================================================================

# -----------------------------------------------------------------------------
# JWT Keys (RS256) — BẮT BUỘC
# Tạo key pair bằng lệnh:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Sau đó copy nội dung file vào đây (giữ nguyên newline dưới dạng \n)
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nMIIB...\n-----END PUBLIC KEY-----"

# -----------------------------------------------------------------------------
# JWT Config — TÙY CHỌN (có giá trị mặc định)
# -----------------------------------------------------------------------------
JWT_ISSUER=auth-service
JWT_AUDIENCE=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# -----------------------------------------------------------------------------
# Google OAuth — BẮT BUỘC
# Lấy tại: https://console.cloud.google.com → APIs & Services → Credentials
# Tạo "OAuth 2.0 Client ID" loại "Web application"
# Thêm GOOGLE_CALLBACK_URL vào "Authorized redirect URIs"
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# -----------------------------------------------------------------------------
# GitHub OAuth — BẮT BUỘC
# Lấy tại: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Điền GITHUB_CALLBACK_URL vào "Authorization callback URL"
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=Iv1.your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# -----------------------------------------------------------------------------
# Redis — TÙY CHỌN (chỉ dùng khi NODE_ENV=production)
# Mặc định: redis://localhost:6379
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Runtime
# Để trống hoặc "development" → dùng InMemoryTokenStore (không cần Redis)
# Set "production" → dùng RedisTokenStore
# -----------------------------------------------------------------------------
NODE_ENV=development
